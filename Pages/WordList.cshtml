@page
@model JPracticeWeb.Pages.WordListModel
@{
    ViewData["Title"] = "단어 목록";
}

<section class="page-shell">
    <div class="card-panel">
        <h1 class="page-title page-title-sm">단어</h1>
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <p class="status-message">@Model.StatusMessage</p>
        }

        @if (Model.Words.Count == 0)
        {
            <p>저장된 단어가 없습니다. 먼저 단어를 추가하세요.</p>
        }
        else
        {
            var leftWords = Model.Words.Take(10).ToList();
            var rightWords = Model.Words.Skip(10).Take(10).ToList();

            <div class="word-columns">
                <div class="word-table-wrap">
                    <table class="word-table">
                        <thead>
                            <tr>
                                <th>단어</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in leftWords)
                        {
                            <tr>
                                <td>
                                    <a class="word-link" asp-page="/WordDetail" asp-route-id="@item.Id" asp-route-p="@Model.CurrentPage">
                                        @item.KoreanWord (@item.DictionaryTerm)
                                    </a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                @if (rightWords.Count > 0)
                {
                    <div class="word-table-wrap">
                        <table class="word-table">
                            <thead>
                                <tr>
                                    <th>단어</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var item in rightWords)
                            {
                                <tr>
                                    <td>
                                        <a class="word-link" asp-page="/WordDetail" asp-route-id="@item.Id" asp-route-p="@Model.CurrentPage">
                                            @item.KoreanWord (@item.DictionaryTerm)
                                        </a>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="pager-row pager-row-compact">
                <div class="pager-cluster">
                    <a class="action-button secondary-button icon-button pager-icon @(Model.CurrentPage <= 1 ? "is-disabled" : string.Empty)"
                       asp-page="/WordList"
                       asp-route-p="@(Model.CurrentPage - 1)"
                       title="이전 페이지"
                       aria-label="이전 페이지">
                        <span aria-hidden="true">&#11013;&#65039;</span>
                    </a>
                    <span class="pager-info">@Model.CurrentPage / @Model.TotalPages 페이지 (@(Model.TotalCount)개)</span>
                    <a class="action-button secondary-button icon-button pager-icon @(Model.CurrentPage >= Model.TotalPages ? "is-disabled" : string.Empty)"
                       asp-page="/WordList"
                       asp-route-p="@(Model.CurrentPage + 1)"
                       title="다음 페이지"
                       aria-label="다음 페이지">
                        <span aria-hidden="true">&#10145;&#65039;</span>
                    </a>
                </div>
            </div>
        }

        <div class="button-row top-gap wordlist-actions">
            <a class="action-button secondary-button icon-button" asp-page="/Index" title="홈" aria-label="홈">
                <span aria-hidden="true">&#127968;</span>
            </a>
            <a class="action-button secondary-button icon-button" asp-page="/AddWord" title="단어 추가" aria-label="단어 추가">
                <span aria-hidden="true">&#10133;</span>
            </a>
        </div>
    </div>
</section>
